# Caddy configuration for KitsuneCore production
# Caddy automatically handles HTTPS with Let's Encrypt

# Environment variables are substituted at runtime
{$DOMAIN_NAME:kitsunecore.com}, {$WWW_DOMAIN_NAME:www.kitsunecore.com} {
    # Enable automatic HTTPS
    # Caddy will automatically obtain and renew certificates
    
    # Email for Let's Encrypt notifications
    tls {$CERTBOT_EMAIL:admin@kitsunecore.com}

    # Increase request body size limit to 30MB
    request_body {
        max_size 30MB
    }

    # Serve favicon directly
    handle /favicon.ico {
        root * /app/static/HomeApp/img
        file_server
    }

    # Serve static files
    handle /static/* {
        root * /app
        file_server
    }

    # Serve media files
    handle /media/* {
        root * /app
        file_server
    }

    # Reverse proxy to Django application
    handle {
        reverse_proxy mainframe:9000 {
            # Forward real client information
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            
            # Timeouts (500 seconds like nginx)
            transport http {
                read_timeout 500s
                write_timeout 500s
                dial_timeout 500s
            }
        }
    }

    # Disable caching
    header {
        Cache-Control "no-cache, no-store, must-revalidate"
        Pragma "no-cache"
        -Server
    }

    # Logging
    log {
        output file /var/log/caddy/access.log
        format json
    }
}

# Redirect IP address access to main domain
http://{$SERVER_IP:0.0.0.0} {
    redir https://{$DOMAIN_NAME:kitsunecore.com}{uri} permanent
}

https://{$SERVER_IP:0.0.0.0} {
    tls {$CERTBOT_EMAIL:admin@kitsunecore.com}
    redir https://{$DOMAIN_NAME:kitsunecore.com}{uri} permanent
}
